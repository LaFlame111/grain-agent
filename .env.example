# V010 环境变量配置模板
# 使用方法：复制此文件为 .env 并填入真实值
#   cp .env.example .env   （Linux / Git Bash）
#   copy .env.example .env  （Windows CMD）

# ====== LLM 配置 ======

# --- 方式一：阿里云通义千问（云端，推荐）---
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=你的通义千问API_Key
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 方式二：本地部署模型（OpenAI 兼容接口）---
# 取消注释以下两行，并注释上面两行
# LLM_MODEL=你的本地模型名称
# LLM_BASE_URL=http://你的本地模型地址:端口/v1

# LLM 调用超时（秒）
# 云端模型建议 60，本地模型建议 180~300（本地推理较慢）
LLM_TIMEOUT=120

# Embedding 配置（RAG 知识检索）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# 可选：调试模式
DEBUG=false

# ====== RAGFlow 企业级 RAG 配置 ======
# RAGFlow 部署后，在 Web UI (http://localhost:80) 的用户设置中获取 API Key
RAGFLOW_API_KEY=你的RAGFlow_API_Key
# RAGFlow 服务地址（默认端口 9380）
RAGFLOW_BASE_URL=http://127.0.0.1:9380
# RAGFlow 数据集 ID（在 Web UI 数据集页面的 URL 中获取，多个用逗号分隔）
RAGFLOW_DATASET_IDS=你的数据集ID

# ====== RAG 增强层配置（rerank_clean 最优参数，一般无需修改）======
# 检索相似度阈值（低于此分数的结果将被丢弃，0-1）
RAG_SIMILARITY_THRESHOLD=0.1
# 最终返回的 Top-K 片段数量
RAG_TOP_K=5
# RAGFlow 检索候选数量（给 reranker 更多候选以提升排序质量）
RAG_PAGE_SIZE=15
# Rerank 模型 ID
RAG_RERANK_ID=gte-rerank
# 是否启用 LLM 查询改写（消融实验证明关闭效果更好）
RAG_ENABLE_QUERY_REWRITE=false
# 查询改写使用的模型（留空则复用 LLM_MODEL）
RAG_QUERY_REWRITE_MODEL=
